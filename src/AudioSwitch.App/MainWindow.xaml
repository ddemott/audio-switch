<Window x:Class="AudioSwitch.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AudioSwitch" Height="640" Width="1200"
        Background="#0D0F14" Foreground="#E5E7EB">
    <Window.Resources>

        <!-- Segoe MDL2 / Fluent glyphs: link = E71B -->
        <Style x:Key="GlyphIcon" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ColumnHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="CountBadge" TargetType="Border">
            <Setter Property="Background" Value="#1F2937" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="8,1" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="#1F2937" />
            <Setter Property="Foreground" Value="#E5E7EB" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Row template factory: the border's BorderBrush is set per-column via a DynamicResource attached below. -->
        <Style x:Key="ComponentListBox" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style x:Key="RowItemContainer" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="RootBorder"
                                Background="#111827"
                                CornerRadius="6"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                Padding="10,8">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{Binding RelativeSource={RelativeSource AncestorType=ListBox}, Path=Tag}" />
                                <Setter TargetName="RootBorder" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#1E293B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ComponentRowTemplate">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Right" Style="{StaticResource GlyphIcon}" Foreground="#6B7280" Text="&#xE71B;" />
                <TextBlock Text="{Binding Name}" Foreground="#E5E7EB" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </DataTemplate>

        <DataTemplate x:Key="ProfileRowTemplate">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Right" Style="{StaticResource GlyphIcon}" Foreground="#6B7280" Text="&#xE71B;" />
                <StackPanel>
                    <TextBlock Text="{Binding Name}" Foreground="#E5E7EB" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Hotkey}" Foreground="#6B7280" FontSize="11" />
                </StackPanel>
            </DockPanel>
        </DataTemplate>

    </Window.Resources>

    <DockPanel Margin="16">
        <StatusBar DockPanel.Dock="Bottom" Background="Transparent" Foreground="#9CA3AF">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready." />
            </StatusBarItem>
        </StatusBar>

        <TextBlock DockPanel.Dock="Top" FontSize="22" FontWeight="Bold" Foreground="#F9FAFB"
                   Text="AudioSwitch" Margin="0,0,0,16" />

        <Grid x:Name="RootGrid">
            <Grid x:Name="ColumnsGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="220" />
                <ColumnDefinition Width="*" MinWidth="220" />
                <ColumnDefinition Width="*" MinWidth="220" />
                <ColumnDefinition Width="*" MinWidth="220" />
            </Grid.ColumnDefinitions>

            <!-- Col 1: Outputs -->
            <DockPanel Grid.Column="0" Margin="0,0,12,0">
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                    <TextBlock Style="{StaticResource GlyphIcon}" Foreground="#34D399" FontSize="16" Text="&#xE7F6;" />
                    <TextBlock Style="{StaticResource ColumnHeader}" Foreground="#34D399" Text="Outputs" Margin="8,0,0,0" />
                    <Border Style="{StaticResource CountBadge}" DockPanel.Dock="Right">
                        <TextBlock x:Name="OutputCountText" Text="0" Foreground="#9CA3AF" />
                    </Border>
                </DockPanel>
                <Button DockPanel.Dock="Bottom" Style="{StaticResource AccentButton}" Content="+ Add output"
                        Click="AddOutput_Click" Margin="0,10,0,0" />
                <ListBox x:Name="OutputsListBox"
                         Style="{StaticResource ComponentListBox}"
                         ItemContainerStyle="{StaticResource RowItemContainer}"
                         ItemTemplate="{StaticResource ComponentRowTemplate}"
                         Tag="#34D399"
                         SelectionChanged="Selection_Changed"
                         MouseRightButtonUp="Component_RightClick" />
            </DockPanel>

            <!-- Col 2: Inputs -->
            <DockPanel Grid.Column="1" Margin="0,0,12,0">
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                    <TextBlock Style="{StaticResource GlyphIcon}" Foreground="#A78BFA" FontSize="16" Text="&#xE720;" />
                    <TextBlock Style="{StaticResource ColumnHeader}" Foreground="#A78BFA" Text="Inputs" Margin="8,0,0,0" />
                    <Border Style="{StaticResource CountBadge}" DockPanel.Dock="Right">
                        <TextBlock x:Name="InputCountText" Text="0" Foreground="#9CA3AF" />
                    </Border>
                </DockPanel>
                <Button DockPanel.Dock="Bottom" Style="{StaticResource AccentButton}" Content="+ Add input"
                        Click="AddInput_Click" Margin="0,10,0,0" />
                <ListBox x:Name="InputsListBox"
                         Style="{StaticResource ComponentListBox}"
                         ItemContainerStyle="{StaticResource RowItemContainer}"
                         ItemTemplate="{StaticResource ComponentRowTemplate}"
                         Tag="#A78BFA"
                         SelectionChanged="Selection_Changed"
                         MouseRightButtonUp="Component_RightClick" />
            </DockPanel>

            <!-- Col 3: Equalizers -->
            <DockPanel Grid.Column="2" Margin="0,0,12,0">
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                    <TextBlock Style="{StaticResource GlyphIcon}" Foreground="#60A5FA" FontSize="16" Text="&#xE9E9;" />
                    <TextBlock Style="{StaticResource ColumnHeader}" Foreground="#60A5FA" Text="Equalizers" Margin="8,0,0,0" />
                    <Border Style="{StaticResource CountBadge}" DockPanel.Dock="Right">
                        <TextBlock x:Name="EqualizerCountText" Text="0" Foreground="#9CA3AF" />
                    </Border>
                </DockPanel>
                <Button DockPanel.Dock="Bottom" Style="{StaticResource AccentButton}" Content="+ Add equalizer"
                        Click="AddEqualizer_Click" Margin="0,10,0,0" />
                <ListBox x:Name="EqualizersListBox"
                         Style="{StaticResource ComponentListBox}"
                         ItemContainerStyle="{StaticResource RowItemContainer}"
                         ItemTemplate="{StaticResource ComponentRowTemplate}"
                         Tag="#60A5FA"
                         SelectionChanged="Selection_Changed"
                         MouseRightButtonUp="Component_RightClick" />
            </DockPanel>

            <!-- Col 4: Profiles (saved link configs) -->
            <DockPanel Grid.Column="3">
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                    <TextBlock Style="{StaticResource GlyphIcon}" Foreground="#F59E0B" FontSize="16" Text="&#xE713;" />
                    <TextBlock Style="{StaticResource ColumnHeader}" Foreground="#F59E0B" Text="Link configs" Margin="8,0,0,0" />
                    <Border Style="{StaticResource CountBadge}" DockPanel.Dock="Right">
                        <TextBlock x:Name="ProfileCountText" Text="0" Foreground="#9CA3AF" />
                    </Border>
                </DockPanel>
                <Button DockPanel.Dock="Bottom" Style="{StaticResource AccentButton}" Content="+ Save current links as config"
                        Click="SaveLinks_Click" Margin="0,10,0,0" />
                <ListBox x:Name="ProfilesListBox"
                         Style="{StaticResource ComponentListBox}"
                         ItemContainerStyle="{StaticResource RowItemContainer}"
                         ItemTemplate="{StaticResource ProfileRowTemplate}"
                         Tag="#F59E0B"
                         SelectionChanged="ProfileSelection_Changed"
                         MouseDoubleClick="Profile_MouseDoubleClick"
                         MouseRightButtonUp="Profile_RightClick" />
            </DockPanel>

            </Grid>
            <!-- Bezier overlay: sibling so it naturally stretches to the outer Grid bounds -->
            <Canvas x:Name="LinkCanvas" IsHitTestVisible="False" Panel.ZIndex="100"
                    ClipToBounds="False" Background="Transparent" />
        </Grid>
    </DockPanel>
</Window>
