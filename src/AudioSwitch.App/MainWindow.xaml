<Window x:Class="AudioSwitch.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AudioSwitch" Height="640" Width="820">
    <DockPanel Margin="12">
        <TextBlock DockPanel.Dock="Top" FontSize="20" FontWeight="Bold" Text="AudioSwitch" />
        <TextBlock DockPanel.Dock="Top" Margin="0,4,0,12" Foreground="Gray"
                   Text="Pick an output device (and optionally an input mic), save as a profile, then double-click to apply." />

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready." />
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0">
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                    <Button x:Name="RefreshButton" Content="Refresh" Padding="10,4" Margin="0,0,8,0" Click="RefreshButton_Click" />
                    <Button x:Name="SaveAsProfileButton" Content="Save selected as profile" Padding="10,4" Click="SaveAsProfileButton_Click" />
                </StackPanel>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0">
                        <TextBlock DockPanel.Dock="Top" FontWeight="Bold" Text="Output devices (required)" Margin="0,0,0,4" />
                        <ListBox x:Name="OutputDevicesList" DisplayMemberPath="Name" />
                    </DockPanel>

                    <DockPanel Grid.Row="2">
                        <DockPanel DockPanel.Dock="Top">
                            <TextBlock FontWeight="Bold" Text="Input devices (optional)" Margin="0,0,8,4" />
                            <Button x:Name="ClearInputButton" DockPanel.Dock="Right" Content="Clear input" Padding="6,1" Click="ClearInputButton_Click" />
                        </DockPanel>
                        <ListBox x:Name="InputDevicesList" DisplayMemberPath="Name" />
                    </DockPanel>
                </Grid>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" Background="Transparent" />

            <DockPanel Grid.Column="2">
                <TextBlock DockPanel.Dock="Top" FontWeight="Bold" Text="Profiles (double-click to apply)" Margin="0,0,0,4" />
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                    <Button x:Name="ApplyButton" Content="Apply selected" Padding="10,4" Margin="0,0,8,0" Click="ApplyButton_Click" />
                    <Button x:Name="DeleteButton" Content="Delete selected" Padding="10,4" Click="DeleteButton_Click" />
                </StackPanel>
                <ListBox x:Name="ProfilesList" MouseDoubleClick="ProfilesList_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock Text="  " />
                                    <TextBlock Text="{Binding Hotkey}" Foreground="Gray" />
                                </StackPanel>
                                <TextBlock Margin="12,2,0,0" FontSize="11" Foreground="DimGray">
                                    <Run Text="Out: " />
                                    <Run Text="{Binding OutputDevice.Name, FallbackValue='(none)', TargetNullValue='(none)'}" />
                                </TextBlock>
                                <TextBlock Margin="12,0,0,0" FontSize="11" Foreground="DimGray">
                                    <Run Text="In:  " />
                                    <Run Text="{Binding InputDevice.Name, FallbackValue='(none)', TargetNullValue='(none)'}" />
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
