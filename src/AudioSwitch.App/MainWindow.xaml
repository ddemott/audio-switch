<Window x:Class="AudioSwitch.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AudioSwitch.App.Controls"
        Title="AudioSwitch" Height="640" Width="1200"
        Background="{DynamicResource SurfaceDefault}"
        Foreground="{DynamicResource TextPrimary}">
    <Window.Resources>

        <Style x:Key="GlyphIcon" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ColumnHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="CountBadge" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BorderSubtle}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="8,1" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BorderSubtle}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComponentListBox" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style x:Key="RowItemContainer" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="RootBorder"
                                Background="{DynamicResource SurfaceElevated}"
                                CornerRadius="6"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                Padding="10,8">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush"
                                        Value="{Binding RelativeSource={RelativeSource AncestorType=ListBox}, Path=(controls:ListBoxAssist.SelectedBorderBrush)}" />
                                <Setter TargetName="RootBorder" Property="BorderThickness" Value="2" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource SurfaceHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ComponentRowTemplate">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Right" Style="{StaticResource GlyphIcon}" Foreground="{DynamicResource TextMuted}" Text="&#xE71B;" />
                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </DataTemplate>

        <DataTemplate x:Key="ProfileRowTemplate">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Right" Style="{StaticResource GlyphIcon}" Foreground="{DynamicResource TextMuted}" Text="&#xE71B;" />
                <StackPanel>
                    <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Hotkey}" Foreground="{DynamicResource TextMuted}" FontSize="11" />
                </StackPanel>
            </DockPanel>
        </DataTemplate>

    </Window.Resources>

    <DockPanel Margin="16">
        <StatusBar DockPanel.Dock="Bottom" Background="Transparent" Foreground="{DynamicResource TextMuted}">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready." />
            </StatusBarItem>
        </StatusBar>

        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <TextBlock FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Text="AudioSwitch" VerticalAlignment="Center" />
            <Button x:Name="ThemeButton" DockPanel.Dock="Right" Padding="10,4"
                    Background="{DynamicResource BorderSubtle}" Foreground="{DynamicResource TextPrimary}"
                    BorderThickness="0" Cursor="Hand" Click="ThemeButton_Click">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Style="{StaticResource GlyphIcon}" Text="&#xE771;" Margin="0,0,6,0" />
                    <TextBlock x:Name="ThemeButtonLabel" Text="Theme" />
                </StackPanel>
            </Button>
        </DockPanel>

        <Grid x:Name="RootGrid">
            <Grid x:Name="ColumnsGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="220" />
                    <ColumnDefinition Width="*" MinWidth="220" />
                    <ColumnDefinition Width="*" MinWidth="220" />
                    <ColumnDefinition Width="*" MinWidth="220" />
                </Grid.ColumnDefinitions>

                <!-- Col 1: Outputs -->
                <DockPanel Grid.Column="0" Margin="0,0,12,0">
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <TextBlock Style="{StaticResource GlyphIcon}" Foreground="{DynamicResource AccentOutput}" FontSize="16" Text="&#xE7F6;" />
                        <TextBlock Style="{StaticResource ColumnHeader}" Foreground="{DynamicResource AccentOutput}" Text="Outputs" Margin="8,0,0,0" />
                        <Border Style="{StaticResource CountBadge}" DockPanel.Dock="Right">
                            <TextBlock x:Name="OutputCountText" Text="0" Foreground="{DynamicResource TextMuted}" />
                        </Border>
                    </DockPanel>
                    <Button DockPanel.Dock="Bottom" Style="{StaticResource AccentButton}" Content="+ Add output"
                            Click="AddOutput_Click" Margin="0,10,0,0" />
                    <ListBox x:Name="OutputsListBox"
                             Style="{StaticResource ComponentListBox}"
                             ItemContainerStyle="{StaticResource RowItemContainer}"
                             ItemTemplate="{StaticResource ComponentRowTemplate}"
                             controls:ListBoxAssist.SelectedBorderBrush="{DynamicResource AccentOutput}"
                             SelectionChanged="Selection_Changed"
                             MouseRightButtonUp="Component_RightClick" />
                </DockPanel>

                <!-- Col 2: Inputs -->
                <DockPanel Grid.Column="1" Margin="0,0,12,0">
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <TextBlock Style="{StaticResource GlyphIcon}" Foreground="{DynamicResource AccentInput}" FontSize="16" Text="&#xE720;" />
                        <TextBlock Style="{StaticResource ColumnHeader}" Foreground="{DynamicResource AccentInput}" Text="Inputs" Margin="8,0,0,0" />
                        <Border Style="{StaticResource CountBadge}" DockPanel.Dock="Right">
                            <TextBlock x:Name="InputCountText" Text="0" Foreground="{DynamicResource TextMuted}" />
                        </Border>
                    </DockPanel>
                    <Button DockPanel.Dock="Bottom" Style="{StaticResource AccentButton}" Content="+ Add input"
                            Click="AddInput_Click" Margin="0,10,0,0" />
                    <ListBox x:Name="InputsListBox"
                             Style="{StaticResource ComponentListBox}"
                             ItemContainerStyle="{StaticResource RowItemContainer}"
                             ItemTemplate="{StaticResource ComponentRowTemplate}"
                             controls:ListBoxAssist.SelectedBorderBrush="{DynamicResource AccentInput}"
                             SelectionChanged="Selection_Changed"
                             MouseRightButtonUp="Component_RightClick" />
                </DockPanel>

                <!-- Col 3: Equalizers -->
                <DockPanel Grid.Column="2" Margin="0,0,12,0">
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <TextBlock Style="{StaticResource GlyphIcon}" Foreground="{DynamicResource AccentEq}" FontSize="16" Text="&#xE9E9;" />
                        <TextBlock Style="{StaticResource ColumnHeader}" Foreground="{DynamicResource AccentEq}" Text="Equalizers" Margin="8,0,0,0" />
                        <Border Style="{StaticResource CountBadge}" DockPanel.Dock="Right">
                            <TextBlock x:Name="EqualizerCountText" Text="0" Foreground="{DynamicResource TextMuted}" />
                        </Border>
                    </DockPanel>
                    <Button DockPanel.Dock="Bottom" Style="{StaticResource AccentButton}" Content="+ Add equalizer"
                            Click="AddEqualizer_Click" Margin="0,10,0,0" />
                    <ListBox x:Name="EqualizersListBox"
                             Style="{StaticResource ComponentListBox}"
                             ItemContainerStyle="{StaticResource RowItemContainer}"
                             ItemTemplate="{StaticResource ComponentRowTemplate}"
                             controls:ListBoxAssist.SelectedBorderBrush="{DynamicResource AccentEq}"
                             SelectionChanged="Selection_Changed"
                             MouseRightButtonUp="Component_RightClick"
                             MouseDoubleClick="EqualizersList_MouseDoubleClick" />
                </DockPanel>

                <!-- Col 4: Profiles -->
                <DockPanel Grid.Column="3">
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <TextBlock Style="{StaticResource GlyphIcon}" Foreground="{DynamicResource AccentProfile}" FontSize="16" Text="&#xE713;" />
                        <TextBlock Style="{StaticResource ColumnHeader}" Foreground="{DynamicResource AccentProfile}" Text="Link configs" Margin="8,0,0,0" />
                        <Border Style="{StaticResource CountBadge}" DockPanel.Dock="Right">
                            <TextBlock x:Name="ProfileCountText" Text="0" Foreground="{DynamicResource TextMuted}" />
                        </Border>
                    </DockPanel>
                    <Button DockPanel.Dock="Bottom" Style="{StaticResource AccentButton}" Content="+ Save current links as config"
                            Click="SaveLinks_Click" Margin="0,10,0,0" />
                    <ListBox x:Name="ProfilesListBox"
                             Style="{StaticResource ComponentListBox}"
                             ItemContainerStyle="{StaticResource RowItemContainer}"
                             ItemTemplate="{StaticResource ProfileRowTemplate}"
                             controls:ListBoxAssist.SelectedBorderBrush="{DynamicResource AccentProfile}"
                             SelectionChanged="ProfileSelection_Changed"
                             MouseDoubleClick="Profile_MouseDoubleClick"
                             MouseRightButtonUp="Profile_RightClick" />
                </DockPanel>
            </Grid>
            <Canvas x:Name="LinkCanvas" IsHitTestVisible="False" Panel.ZIndex="100"
                    ClipToBounds="False" Background="Transparent" />
        </Grid>
    </DockPanel>
</Window>
