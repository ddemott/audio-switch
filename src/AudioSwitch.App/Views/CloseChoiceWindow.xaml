<Window x:Class="AudioSwitch.App.Views.CloseChoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Close AudioSwitch?"
        Width="420" SizeToContent="Height"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource SurfaceDefault}"
        Foreground="{DynamicResource TextPrimary}">
    <StackPanel Margin="18">
        <TextBlock Text="Close AudioSwitch?" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8" />
        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextMuted}"
                   Text="AudioSwitch can keep running in the system tray so your hotkeys and profiles stay active. What would you like to do?"
                   Margin="0,0,0,14" />

        <CheckBox x:Name="RememberCheckBox" Content="Don't ask again" Margin="0,0,0,14"
                  Foreground="{DynamicResource TextPrimary}" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="MinimizeButton" Content="Minimize to tray" Padding="12,6" MinWidth="130"
                    Click="MinimizeButton_Click"
                    Background="{DynamicResource AccentProfile}" Foreground="White"
                    BorderThickness="0" Cursor="Hand" />
            <Button x:Name="CloseButton" Content="Close app" Padding="12,6" MinWidth="110" Margin="8,0,0,0"
                    Click="CloseButton_Click"
                    Background="{DynamicResource BorderSubtle}" Foreground="{DynamicResource TextPrimary}"
                    BorderThickness="0" Cursor="Hand" />
            <Button x:Name="CancelButton" Content="Cancel" Padding="12,6" MinWidth="90" Margin="8,0,0,0"
                    Click="CancelButton_Click"
                    Background="{DynamicResource BorderSubtle}" Foreground="{DynamicResource TextPrimary}"
                    BorderThickness="0" Cursor="Hand" IsCancel="True" />
        </StackPanel>
    </StackPanel>
</Window>
