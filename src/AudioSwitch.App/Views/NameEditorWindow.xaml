<Window x:Class="AudioSwitch.App.Views.NameEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename" Height="140" Width="400"
        Background="#0D0F14" Foreground="#E5E7EB"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <DockPanel Margin="18">
        <TextBlock x:Name="PromptText" DockPanel.Dock="Top" Margin="0,0,0,10" Text="New name" />
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Padding="14,6" Margin="0,0,8,0"
                    Background="#1F2937" Foreground="#E5E7EB" BorderThickness="0"
                    IsCancel="True" Click="Cancel_Click" />
            <Button Content="OK" Padding="14,6" IsDefault="True"
                    Background="#60A5FA" Foreground="#0B1020" BorderThickness="0" FontWeight="SemiBold"
                    Click="Ok_Click" />
        </StackPanel>
        <TextBox x:Name="NameBox" Background="#111827" Foreground="#E5E7EB"
                 BorderBrush="#374151" BorderThickness="1" Padding="6,4" FontSize="14" />
    </DockPanel>
</Window>
