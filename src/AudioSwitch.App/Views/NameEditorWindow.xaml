<Window x:Class="AudioSwitch.App.Views.NameEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename" SizeToContent="Height" Width="420"
        Background="{DynamicResource SurfaceDefault}" Foreground="{DynamicResource TextPrimary}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False"
        FocusManager.FocusedElement="{Binding ElementName=NameBox}">
    <DockPanel Margin="18">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Padding="14,6" Margin="0,0,8,0"
                    Background="{DynamicResource BorderSubtle}" Foreground="{DynamicResource TextPrimary}"
                    BorderThickness="0" IsCancel="True" Click="Cancel_Click" />
            <Button Content="OK" Padding="14,6" IsDefault="True"
                    Background="{DynamicResource AccentEq}" Foreground="{DynamicResource TextOnAccent}"
                    BorderThickness="0" FontWeight="SemiBold" Click="Ok_Click" />
        </StackPanel>
        <TextBox x:Name="NameBox" />
    </DockPanel>
</Window>
