<Window x:Class="AudioSwitch.App.Views.ProfileVolumesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit volumes" Height="380" Width="560"
        Background="{DynamicResource SurfaceDefault}" Foreground="{DynamicResource TextPrimary}"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="GlyphIcon" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </Window.Resources>
    <DockPanel Margin="22,18,22,18">
        <TextBlock x:Name="HeaderText" DockPanel.Dock="Top" FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4" />
        <TextBlock DockPanel.Dock="Top" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"
                   Margin="0,0,0,14"
                   Text="Adjust this profile's level for each device. Leaving a slider unchanged keeps the device's default volume." />

        <DockPanel DockPanel.Dock="Bottom" Margin="0,16,0,0">
            <Button DockPanel.Dock="Left" Content="Reset all to defaults" Padding="12,6"
                    Background="{DynamicResource BorderSubtle}" Foreground="{DynamicResource TextPrimary}"
                    BorderThickness="0" Click="Reset_Click" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                <Button Content="Cancel" Padding="14,6" Margin="0,0,8,0" IsCancel="True"
                        Background="{DynamicResource BorderSubtle}" Foreground="{DynamicResource TextPrimary}"
                        BorderThickness="0" Click="Cancel_Click" />
                <Button Content="Save" Padding="14,6" IsDefault="True"
                        Background="{DynamicResource AccentProfile}" Foreground="{DynamicResource TextOnAccent}"
                        BorderThickness="0" FontWeight="SemiBold" Click="Save_Click" />
            </StackPanel>
        </DockPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="RowList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,4,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="48" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource GlyphIcon}"
                                       Foreground="{Binding AccentBrush}" Text="{Binding GlyphIcon}"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimary}" Margin="6,0,8,0" TextTrimming="CharacterEllipsis" />
                            <Slider Grid.Column="2" Minimum="0" Maximum="100"
                                    Value="{Binding Volume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    SmallChange="1" LargeChange="5" TickFrequency="10" TickPlacement="BottomRight"
                                    Foreground="{Binding AccentBrush}" />
                            <TextBlock Grid.Column="3" Text="{Binding VolumeLabel, Mode=OneWay}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextMuted}" Margin="8,0,0,0" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
